# Copy to terraform.tfvars and adjust. All values have sane defaults.

github_owner    = "jmelahman"
repository_name = "muir"
default_branch  = "master"

# Audit backend: "openrouter" | "claude-cli" | "anthropic"
audit_backend = "openrouter"
# Optional model override (OpenRouter slug, or Claude model id). Empty = default.
audit_model = ""

# GitHub App ID of the muir bot. Every PR needs a code-owner review, but this
# App bypasses it so the bot's vetted PRs auto-merge (human PRs still need you).
# Leave 0 until the App exists — see .github/bot-app.md.
bot_app_id = 0
