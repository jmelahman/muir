# Vetted, signed builds from your mirror. Append this stanza to /etc/pacman.conf
# so pacman/yay install these from here instead of building from the AUR.
# (Generated by ./bootstrap.sh from contrib/pacman-repo.conf.in.)
[@REPO@]
SigLevel = Required
Server = https://github.com/@OWNER@/@REPO@/releases/download/repo
